{
  "name": "cortex",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:prod": "next start -H 0.0.0.0 -p 3000",
    "postinstall": "prisma generate",
    "docker:build": "docker build -t bidbuild-web:latest .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "worker": "tsx workers/agent.worker.ts",
    "worker:crm": "tsx workers/crm.worker.ts",
    "stack:crm": "pwsh -ExecutionPolicy Bypass -File .\\scripts\\start_crm_stack.ps1",
    "lint": "eslint",
    "test:e2e:platform": "tsx tests/platform-flows.e2e.ts",
    "backtest:estimator": "tsx scripts/run_estimator_backtest.ts",
    "backtest:estimator:ps": "pwsh -ExecutionPolicy Bypass -File .\\scripts\\run_estimator_backtest.ps1",
    "audit:builders": "tsx scripts/run_builder_audit.ts",
    "audit:platform": "tsx scripts/audit_platform_systems.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bullmq": "^5.71.0",
    "ioredis": "^5.10.0",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pusher": "^5.3.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
