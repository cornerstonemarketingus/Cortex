generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Existing Bot model (keeps backward compatibility)
model Bot {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  createdAt DateTime @default(now())
  memories  Memory[]
}

// New Memory model used by the API route
model Memory {
  id        Int      @id @default(autoincrement())
  agent     String
  message   String
  createdAt DateTime @default(now())
  botId     Int?
  bot       Bot?     @relation(fields: [botId], references: [id])
}