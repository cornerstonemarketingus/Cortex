generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Existing Bot model (keeps backward compatibility)
model Bot {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  createdAt DateTime @default(now())
  memories  Memory[]
}

// New Memory model used by the API route
model Memory {
  id        Int      @id @default(autoincrement())
  agent     String
  message   String
  createdAt DateTime @default(now())
  botId     Int?
  bot       Bot?     @relation(fields: [botId], references: [id])
}

model WorkspaceState {
  id                Int                 @id @default(autoincrement())
  ownerKey          String              @unique
  modelJson         Json
  updatedAt         DateTime            @updatedAt
  currentRevisionId Int?
  revisions         WorkspaceRevision[]
}

model WorkspaceRevision {
  id          Int            @id @default(autoincrement())
  workspaceId Int
  label       String
  modelJson   Json
  createdAt   DateTime       @default(now())
  workspace   WorkspaceState @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model BuilderPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  sections  Json
  seoMeta   Json?
  published Boolean  @default(false)
  ownerKey  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}